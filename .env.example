# ── Backend (Render free tier) ──────────────────────────────────────────────
# APP_ENV=staging bypasses production guards (redis, S3, strict key checks)
# that would crash startup on Render free tier.
APP_ENV=staging
PORT=10000

OPENAI_API_KEY=sk-...

# Comma-separated — at least one value required for requests to be authenticated.
# Generate with: openssl rand -hex 32
ADMIN_API_KEYS=your-admin-key-here
USER_API_KEYS=your-user-key-here

# Must include your Vercel deployment URL for CORS to allow browser requests.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Supabase / Neon / Railway Postgres connection string
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# Storage — keep "local" on Render free tier (no S3 needed)
STORAGE_BACKEND=local

# Rate limiting — keep "memory" (no Redis on free tier)
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_ENABLED=true

# Chroma vector store — persist to /app/chroma_data (writable in Docker)
VIDEO_CHROMA_PERSIST_DIR=/app/chroma_data

# SQLite conversation checkpointer — writable path inside the container
CHAT_CHECKPOINTER_BACKEND=sqlite
CHAT_CHECKPOINTER_PATH=data/chat_checkpoints.sqlite

# Optional
COHERE_API_KEY=
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# ── Frontend (Vercel) ────────────────────────────────────────────────────────
# Set these in Vercel dashboard → Project → Settings → Environment Variables.
# NEXT_PUBLIC_API_URL is the primary var name read by frontend/lib/settings.tsx.
NEXT_PUBLIC_API_URL=https://creator-rag-backend.onrender.com
# Must match one of ADMIN_API_KEYS or USER_API_KEYS above.
NEXT_PUBLIC_RAG_API_KEY=same-as-ADMIN_API_KEYS-value
